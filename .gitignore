# ── Compiled / shipped binaries (never commit binaries to git) ─────────────
Cis-GS.exe
Cis-GS.app/
cis-gs
*.exe
*.dmg
*.AppImage

# ── IDE / agent / editor ───────────────────────────────────────────────────
.vscode/
.idea/
.cursor/
.claude/
*.swp
*.swo
*~

# ── OS junk ────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── User-generated workspace (per-user genome cache, settings, etc.) ───────
workspace/
CisGS-Workspace/
cis_gs/workspace/
.ncbi_email
.theme

# ── PyPI / Twine credentials ───────────────────────────────────────────────
.pypirc
*.token

# ── Documentation build output ─────────────────────────────────────────────
docs/_build/
docs/build/
docs/source/_autosummary/
site/

# ── Test / coverage artifacts ──────────────────────────────────────────────
.coverage
.coverage.*
htmlcov/
.pytest_cache/
.tox/

# ── Jupyter checkpoints ────────────────────────────────────────────────────
.ipynb_checkpoints/
